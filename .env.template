# Interactive Brokers Paper Trading Configuration
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

# Paper trading username (separate from live username)
IBKR_USERNAME=

# Paper trading password
IBKR_PASSWORD=

# IB Gateway / TWS host (default: localhost)
IBKR_HOST=127.0.0.1

# IB Gateway / TWS API port (default: 4001)
IBKR_PORT=4001

# Trading mode: PAPER or LIVE
IBKR_TRADE_MODE=PAPER

# Client ID (unique per API connection, default: 1)
# Use different IDs if running multiple connections simultaneously
IBKR_CLIENT_ID=1